{
  "installCommand": "npm install",
  "buildCommand": "node scripts/refresh.js",
  "outputDirectory": ".",
  "crons": [
    { "path": "/api/redeploy", "schedule": "0 7 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
