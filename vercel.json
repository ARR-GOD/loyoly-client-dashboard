{
  "buildCommand": "cp index.html public/index.html && cp data/clients.json public/data/clients.json",
  "outputDirectory": "public",
  "installCommand": "mkdir -p public/data",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
